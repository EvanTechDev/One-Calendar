{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@onecalendar/types": ["../types/src/index.ts"],
      "@onecalendar/crypto": ["../crypto/src/index.ts"],
      "@onecalendar/i18n": ["../i18n/src/index.ts"]
    }
  }
}
