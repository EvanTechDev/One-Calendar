{
  "name": "@zntr/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.tsx"
  },
  "scripts": {
    "build": "tsc",
    "build:check": "tsc && tsc --noEmit",
    "lint": "oxlint --fix --config ../../config/oxlint.json src && eslint --config ../../config/eslint.config.ts src --fix",
    "lint:check": "oxlint --config ../../config/oxlint.json src && eslint --config ../../config/eslint.config.ts src --quiet",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@zntr/utils": "workspace:*",
    "@radix-ui/react-toast": "1.2.17",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "1.21.0",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
    "recharts": "3.9.0",
    "sonner": "2.0.7",
    "radix-ui": "latest",
    "cobe": "0.6.4",
    "motion": "^12.41.0",
    "next-themes": "latest"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}
