generator client {
  provider = "prisma-client-js"
  output   = "./lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  authSalt            String    @map("auth_salt")
  keySalt             String    @map("key_salt")
  backupSalt          String    @map("backup_salt")
  authHash            String    @map("auth_hash")
  wrappedMasterKey    String    @map("wrapped_master_key")
  wrappedMasterKeyIv  String    @map("wrapped_master_key_iv")
  sessions            Session[]
  events              CalendarEvent[]

  @@map("users")
}

model Session {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  token         String   @unique
  sessionSecret String   @map("session_secret")
  createdAt     DateTime @default(now()) @map("created_at")
  expiresAt     DateTime @map("expires_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_sessions_user_id")
  @@map("sessions")
}

model CalendarEvent {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  ciphertext String
  iv         String
  wrappedDek String   @map("wrapped_dek")
  dekIv      String   @map("dek_iv")
  startTime  DateTime @map("start_time")
  endTime    DateTime @map("end_time")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startTime, endTime], map: "idx_events_user_time")
  @@map("calendar_events")
}
