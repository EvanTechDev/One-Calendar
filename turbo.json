{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "POSTGRES_URL",
    "NEXT_PUBLIC_DS_URL",
    "ATPROTO_DID_PRIVATE_KEY",
    "ATPROTO_DEMO_DID",
    "ATPROTO_DEMO_HANDLE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "db:migrate": {
      "cache": false,
      "outputs": []
    }
  }
}
