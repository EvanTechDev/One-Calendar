{
  "name": "one-calendar-monorepo",
  "version": "3.0.0-rc.1",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "pnpm --filter @one-calendar/calendar start",
    "lint": "turbo lint",
    "lint:check": "turbo lint:check",
    "type-check": "turbo type-check",
    "generate:i18n": "turbo generate:i18n",
    "cleanup:i18n": "turbo cleanup:i18n",
    "prepare": "husky"
  },
  "devDependencies": {
    "@nx/js": "latest",
    "nx": "latest",
    "turbo": "latest",
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@commitlint/types": "20.5.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.8.4"
  },
  "lint-staged": {
    "apps/calendar/**/*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "pnpm --filter @one-calendar/calendar exec oxlint --fix",
      "pnpm --filter @one-calendar/calendar exec eslint --fix"
    ],
    "apps/calendar/**/*.{json,md,css}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
