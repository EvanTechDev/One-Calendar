{
  "name": "zntr",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "prepare": "husky",
    "lint": "turbo lint",
    "lint:check": "turbo lint:check",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "generate:i18n": "pnpm --filter @zntr/i18n generate",
    "cleanup:i18n": "pnpm --filter @zntr/i18n cleanup",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@commitlint/types": "20.5.0",
    "@eslint/js": "10.0.1",
    "@next/eslint-plugin-next": "16.2.9",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "latest",
    "eslint": "10.5.0",
    "eslint-plugin-oxlint": "1.71.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "next": "16.2.9",
    "oxlint": "1.71.0",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0"
  }
}
