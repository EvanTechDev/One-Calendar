  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "latest",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3"
