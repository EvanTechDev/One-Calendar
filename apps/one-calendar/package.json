    "type-check": "tsc --noEmit",
    "generate:i18n": "node lib/gen-locales.mjs",
    "cleanup:i18n": "node lib/cleanup-i18n.mjs"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.20",
    "@better-auth/infra": "0.3.2",
    "@marsidev/react-turnstile": "1.5.3",
    "bcryptjs": "latest",
    "better-auth": "1.6.20",
    "cobe": "0.6.4",
    "date-fns": "4.4.0",
    "drizzle-orm": "^0.45.2",
    "evlog": "2.19.2",
    "framer-motion": "12.41.0",
    "geist": "latest",
    "lucide-react": "1.21.0",
    "motion": "^12.41.0",
    "next": "16.2.9",
    "next-themes": "latest",
    "postgres": "^3.4.9",
    "qr-code-styling": "latest",
    "react": "19.2.7",
    "react-email": "6.6.4",
    "react-icons": "5.6.0",
    "recharts": "3.9.0",
    "resend": "6.14.0",
