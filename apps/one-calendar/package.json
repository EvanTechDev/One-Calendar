{
  "name": "one-calendar",
  "version": "3.0.0-rc.1",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm --silent run generate:i18n && next build",
    "start": "next start",
