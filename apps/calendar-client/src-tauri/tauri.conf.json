{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "One Calendar",
  "version": "0.1.0",
  "identifier": "app.zntr.calendar",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "https://calendar.xyehr.cn/app",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "https://calendar.xyehr.cn/app"
  },
  "app": {
    "windows": [
      {
        "title": "One Calendar",
        "width": 1920,
        "height": 1200,
        "url": "https://calendar.xyehr.cn/app"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
